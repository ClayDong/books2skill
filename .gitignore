!lark-cli.json.template

# API keys / tokens（任何可能包含密钥的配置）
secrets.json
config.local.json
*secret*
*apikey*
*api_key*
*token*

# ===== 运行时生成数据 =====
# 多书协同产出层（运行时生成，包含本地拆书数据）
library/

# 单书蒸馏产出（运行时生成，按需保留本地）
# 注意：如果你想分享拆完的 skill packs，请放在独立仓库
output/
outputs/
dist/
build/

