# Cangjie Skill Configuration
# Copy this file to .env and modify the values

# Project Paths
PROJECT_ROOT="."
BOOKS_RAW_DIR="./books_raw/书股"
BOOKS_TXT_DIR="./books_txt"
BOOKS_TXT_OCR_DIR="./books_txt_ocr"
LIBRARY_DIR="./library"
OUTPUT_DIR="./output"

# OCR Configuration
OCR_DPI=200
OCR_LANG="ch"
OCR_USE_ANGLE_CLS=true
OCR_USE_GPU=false  # Set to true if you have GPU support

# Processing Configuration
MAX_WORKERS=4  # Number of parallel workers
CHUNK_SIZE=1000  # Text chunk size for processing
CACHE_ENABLED=true
CACHE_TTL=86400  # Cache TTL in seconds (24 hours)

# Validation Configuration
VALIDATION_STRICT=true
VALIDATION_TIMEOUT=300  # Validation timeout in seconds
MIN_SKILL_QUALITY_SCORE=0.7  # Minimum quality score for skills

# Logging Configuration
LOG_LEVEL="INFO"
LOG_FORMAT="json"  # json or text
LOG_FILE="./logs/cangjie.log"
LOG_ROTATION="10 MB"
LOG_RETENTION="30 days"

# API Configuration (if using external APIs)
OPENAI_API_KEY=""  # Optional: for LLM-based enhancements
ANTHROPIC_API_KEY=""  # Optional: for Claude API
COHERE_API_KEY=""  # Optional: for Cohere API

# Performance Configuration
ENABLE_PROFILING=false
PROFILING_OUTPUT="./profiling"
MAX_MEMORY_USAGE="2GB"  # Maximum memory usage limit

# Development Configuration
DEBUG=false
TEST_MODE=false
SKIP_VALIDATION=false
FAST_MODE=false  # Skip some quality checks for faster processing

# Export Configuration
EXPORT_FORMAT="markdown"  # markdown, json, or both
EXPORT_INCLUDE_METADATA=true
EXPORT_INCLUDE_VALIDATION=true
